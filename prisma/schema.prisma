// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  username      String    @unique @default(cuid()) // Unique handle
  pseudo        String    // Display name
  avatarUrl     String?
  bannerUrl     String?
  bio           String?
  status        String?   // Custom status message
  accentColor   String?   // Hex color code
  socialLinks   String?   // JSON string of social links
  state         String    @default("ONLINE") // ONLINE, IDLE, DND, INVISIBLE
  role          String    @default("MEMBER") // Global role: ADMIN, MODERATOR, MEMBER
  isHost        Boolean   @default(false)
  publicKey     String?
  privateKey    String?   // Encrypted with MASTER_ENCRYPTION_KEY
  isBanned      Boolean   @default(false)
  banExpiresAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  messages      Message[]
  reactions     Reaction[]
  servers       ServerMember[]
  ownedServers  Server[]
  channels      Channel[] @relation("ChannelMembers")
  
  friends       User[]    @relation("UserFriends")
  friendOf      User[]    @relation("UserFriends")
  
  bans          ServerBan[]
}

model Server {
  id          String    @id @default(uuid())
  name        String
  imageUrl    String?
  inviteCode  String    @unique @default(cuid())
  isInviteCodeVisible Boolean @default(true)
  ownerId     String
  owner       User      @relation(fields: [ownerId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  categories  Category[]
  members     ServerMember[]
  roles       Role[]
  bans        ServerBan[]
}

model ServerBan {
  id        String   @id @default(uuid())
  userId    String
  serverId  String
  reason    String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  server    Server   @relation(fields: [serverId], references: [id])

  @@unique([userId, serverId])
}

model Role {
  id          String    @id @default(uuid())
  name        String
  color       String    @default("#99AAB5") // Hex or Gradient
  position    Int       @default(0)
  permissions String    @default("VIEW_CHANNELS") // JSON string of permissions
  iconUrl     String?
  serverId    String
  server      Server    @relation(fields: [serverId], references: [id], onDelete: Cascade)
  members     ServerMember[]
  allowedChannels Channel[] @relation("ChannelRoles")
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ServerMember {
  id        String   @id @default(uuid())
  userId    String
  serverId  String
  // Deprecated: use roles relation instead
  role      String   @default("MEMBER") 
  
  user      User     @relation(fields: [userId], references: [id])
  server    Server   @relation(fields: [serverId], references: [id])
  roles     Role[]
  
  joinedAt  DateTime @default(now())

  @@unique([userId, serverId])
}

model Category {
  id        String    @id @default(uuid())
  name      String
  serverId  String
  server    Server    @relation(fields: [serverId], references: [id])
  channels  Channel[]
}

model Channel {
  id          String    @id @default(uuid())
  name        String
  type        String    @default("TEXT") // TEXT, VOICE, DM
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  messages    Message[]
  members     User[]    @relation("ChannelMembers")
  allowedRoles Role[]   @relation("ChannelRoles")
  isPrivate    Boolean  @default(false)
}

model Message {
  id          String    @id @default(uuid())
  content     String    // Encrypted content
  isEmbed     Boolean   @default(false)
  embedData   String?   // JSON string of embed data
  gifUrl      String?
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  channelId   String
  channel     Channel   @relation(fields: [channelId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
  reactions   Reaction[]
  
  isForwarded   Boolean   @default(false)
  forwardedFrom String?   // ID or Link of the original message
}

model Reaction {
  id        String   @id @default(uuid())
  emoji     String
  messageId String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  message   Message  @relation(fields: [messageId], references: [id])
  createdAt DateTime @default(now())

  @@unique([messageId, userId, emoji])
}

model Log {
  id        String   @id @default(uuid())
  action    String
  details   String
  adminId   String
  createdAt DateTime @default(now())
}
